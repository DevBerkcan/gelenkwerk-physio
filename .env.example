# ─── SMTP Configuration for Booking Emails ───
# Configure these to enable email notifications.
# Without these, bookings are logged to the console only.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@gelenkwerk.ch
SMTP_PASS=your-password-here

# The email address that receives booking notifications
PRACTICE_EMAIL=info@gelenkwerk.ch
